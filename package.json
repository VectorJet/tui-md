{
  "name": "tui-md",
  "version": "0.1.8",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist --target node --external @opentui/core --external @opentui/react --external react",
    "test": "bun run typecheck && bun run build",
    "typecheck": "tsc --noEmit",
    "test:interactive": "bun run tests/interactive.tsx",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "hast-util-to-string": "^3.0.1",
    "image-dimensions": "^2.5.1",
    "rehype-raw": "^7.0.0",
    "remark-abbr": "^1.4.2",
    "remark-definition-list": "^2.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.16",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@opentui/core": "*",
    "@opentui/react": "*",
    "react": ">=18"
  },
  "license": "MIT"
}
