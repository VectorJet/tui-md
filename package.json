{
  "name": "tui-md",
  "version": "0.1.0",
  "description": "OpenTUI React markdown renderer.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.tsx --outdir ./dist --target node --packages external && tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "test:interactive": "bun run tests/interactive.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun run typecheck && bun run build"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "hast-util-to-string": "^3.0.1",
    "katex": "^0.17.0",
    "rehype-raw": "^7.0.0",
    "remark-abbr": "^1.4.2",
    "remark-definition-list": "^2.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.16",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@opentui/core": "*",
    "@opentui/react": "*",
    "react": ">=19.2.0"
  }
}
